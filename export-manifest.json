{
  "$schema": "./schemas/export-manifest.schema.json",
  "sourceVault": "D:/studio/服务器存放的笔记",
  "site": {
    "title": "evil的公开笔记",
    "description": "从私人 Obsidian 笔记库整理出的公开技术草稿。",
    "author": "evil",
    "language": "zh_CN"
  },
  "sensitive": {
    "privatePaths": [".obsidian", ".trash", ".vscode", "密码", "密钥", "学校邮箱", "日记"],
    "blockedExtensions": [
      ".pem",
      ".key",
      ".p12",
      ".pfx",
      ".env",
      ".zip",
      ".7z",
      ".rar",
      ".docx",
      ".pptx",
      ".pdf"
    ],
    "reviewTerms": ["密码", "密钥", "pem", "token", "secret", "email", "private key"]
  },
  "import": {
    "excludeRoots": [".git", ".obsidian", ".trash", ".vscode", "public-notes", "密码", "密钥", "学校邮箱"],
    "personalSegments": ["日记", "模板", "模版", "网络工程专业职业规划报告"],
    "personalNamePatterns": ["日报", "周报", "计划", "汇报", "职业规划"]
  },
  "entries": [
    {
      "status": "private",
      "source": "密码/",
      "reason": "密码类内容永不发布。"
    },
    {
      "status": "private",
      "source": "密钥/",
      "reason": "密钥、SSH 私钥和凭据类内容永不发布。"
    },
    {
      "status": "private",
      "source": "日记/",
      "reason": "私人日记永不进入公开站点。"
    },
    {
      "status": "private",
      "source": "26寒假学习/日记/",
      "reason": "私人日记永不进入公开站点。"
    },
    {
      "status": "private",
      "source": "学校邮箱/",
      "reason": "包含学校邮箱申请材料和截图，永不发布。"
    },
    {
      "status": "private",
      "source": ".obsidian/",
      "reason": "Obsidian 工作区、插件和缓存配置不进入公开站点。"
    },
    {
      "status": "private",
      "source": ".trash/",
      "reason": "回收站内容不进入公开站点。"
    },
    {
      "status": "private",
      "source": ".vscode/",
      "reason": "本地编辑器配置不进入公开站点。"
    },
    {
      "status": "private",
      "source": "public-notes/",
      "reason": "旧生成站点目录不作为新 Fuwari 内容来源。"
    }
  ]
}
