{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["sourceVault", "site", "entries"],
  "properties": {
    "sourceVault": { "type": "string" },
    "site": {
      "type": "object",
      "required": ["title", "description", "author", "language"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "sensitive": {
      "type": "object",
      "properties": {
        "privatePaths": { "type": "array", "items": { "type": "string" } },
        "blockedExtensions": { "type": "array", "items": { "type": "string" } },
        "reviewTerms": { "type": "array", "items": { "type": "string" } }
      }
    },
    "import": {
      "type": "object",
      "properties": {
        "excludeRoots": { "type": "array", "items": { "type": "string" } },
        "personalSegments": { "type": "array", "items": { "type": "string" } },
        "personalNamePatterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status", "source"],
        "properties": {
          "status": { "enum": ["draft", "publish", "review", "private", "imported", "excluded"] },
          "source": { "type": "string" },
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "date": { "type": "string" },
          "updated": { "type": "string" },
          "category": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
